{
  "name": "toolset",
  "version": "1.0.1",
  "description": "工具集 - 集成多种实用工具的桌面应用",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "node scripts/generate-icons.mjs && vite",
    "dev:renderer": "node scripts/generate-icons.mjs && vite --config vite.renderer.config.ts",
    "dev:electron": "NODE_ENV=development electron --no-sandbox --disable-gpu --disable-software-rasterizer dist/main/index.js",
    "build": "node scripts/generate-icons.mjs && tsc && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack": "npm run build && electron-builder --win --config electron-builder.yml --publish never",
    "pack:mac": "npm run build && electron-builder --mac --config electron-builder.yml --publish never",
    "pack:all": "npm run build && electron-builder --win --mac --config electron-builder.yml --publish never",
    "dist": "npm run build && electron-builder --win --config electron-builder.yml --publish never"
  },
  "dependencies": {
    "@toolsets/shared": "file:./shared",
    "adm-zip": "^0.5.17",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^20.17.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "sharp": "^0.35.2",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.28.8",
    "vitest": "^3.2.6"
  }
}
